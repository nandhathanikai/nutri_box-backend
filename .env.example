# ─── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-real-random-48-byte-string

# ─── Storage (Supabase) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_BUCKET=menu-images

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Used to verify Razorpay → backend webhook callbacks. Set the same value in
# Razorpay Dashboard → Settings → Webhooks → Secret. Without this the
# /api/payments/webhook endpoint will reject everything.
RAZORPAY_WEBHOOK_SECRET=

# ─── Email (Brevo / Sendinblue) ───────────────────────────────────────────────
# Transactional email API key. If unset, emails are logged to console (dev mode).
BREVO_API_KEY=
FROM_EMAIL=noreply@nutribox.app
FROM_NAME=NutriBox

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Legacy SMTP config — kept for reference. Brevo API is preferred.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@nutribox.app

# ─── Optional ─────────────────────────────────────────────────────────────────
# Comma-separated list of additional CORS origins (production frontend domain).
FRONTEND_ORIGINS=

# Public frontend base URL used when building email-verification links.
# Falls back to the first entry in FRONTEND_ORIGINS, then localhost:4200 in dev.
FRONTEND_BASE_URL=

# Set to "true" to disable the in-process daily scheduler (e.g. when running
# behind multiple instances and using an external cron).
DISABLE_SCHEDULER=false

# Set to "true" to run Base.metadata.create_all() on startup (first deploy only).
# After initial setup, use Alembic migrations instead.
AUTO_CREATE_TABLES=true

# ─── Logging ──────────────────────────────────────────────────────────────────
# "json" for structured logs (production), "text" for human-readable (dev)
LOG_FORMAT=text
# Python log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
